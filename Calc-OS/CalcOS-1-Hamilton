// Master Mode Switcher
void setMode(AppMode newMode) {
  currentMode = newMode;
  switch (currentMode) {
    case MODE_HOME:      renderHomeScreen(); break;
    case MODE_GRAPH:     plotGraph(currentEquation); break;
    case MODE_FUNCTIONS: renderFunctionsScreen(); break;
    case MODE_INFO:      renderInfoScreen(); break;
  }
}

