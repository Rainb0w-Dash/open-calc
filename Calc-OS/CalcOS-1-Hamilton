// --- Horizontal Graph Plotter with Titlebar Indicator (320 x 240) ---
void plotGraph(String equation, float xMin = -10.0, float xMax = 10.0, float yMin = -7.5, float yMax = 7.5) {
  tft.setRotation(1); // Widescreen / Landscape
  tft.fillScreen(ILI9341_BLACK);

  int width = tft.width();
  int height = tft.height();

  // Axis zero positions
  int zeroX = (int)((0 - xMin) / (xMax - xMin) * width);
  int zeroY = height - 18 - (int)((0 - yMin) / (yMax - yMin) * (height - 40));

  // 1. Draw Grid Lines & Numbers
  tft.setTextSize(1);
  tft.setTextColor(0x7BEF); // Darker gray for scale numbers

  // X-Axis Grid & Tick Numbers
  for (float x = ceil(xMin); x <= xMax; x += 2.0) {
    int px = (int)((x - xMin) / (xMax - xMin) * width);
    tft.drawFastVLine(px, 22, height - 40, 0x18E3);

    int val = (int)x;
    if (val % 4 == 0 && val != 0) {
      int lblY = (zeroY >= 22 && zeroY <= height - 30) ? zeroY + 4 : height - 30;
      tft.setCursor(px - 6, lblY);
      tft.print(val);
    }
  }

  // Y-Axis Grid & Tick Numbers
  for (float y = ceil(yMin); y <= yMax; y += 2.0) {
    int py = height - 18 - (int)((y - yMin) / (yMax - yMin) * (height - 40));
    tft.drawFastHLine(0, py, width, 0x18E3);

    int val = (int)y;
    if (val % 4 == 0 && val != 0) {
      int lblX = (zeroX >= 10 && zeroX <= width - 25) ? zeroX + 4 : 5;
      tft.setCursor(lblX, py - 3);
      tft.print(val);
    }
  }

  // 2. Draw Solid Main Axes Lines
  if (zeroX >= 0 && zeroX < width) tft.drawFastVLine(zeroX, 22, height - 40, ILI9341_WHITE);
  if (zeroY >= 22 && zeroY < height - 18) tft.drawFastHLine(0, zeroY, width, ILI9341_WHITE);

  // 3. Draw Axis Labels ("X" and "Y")
  tft.setTextColor(ILI9341_YELLOW);
  if (zeroX >= 0 && zeroX < width - 15) {
    tft.setCursor(zeroX + 5, 25);
    tft.print("Y");
  }
  if (zeroY >= 22 && zeroY < height - 18) {
    tft.setCursor(width - 12, zeroY - 10);
    tft.print("X");
  }

  // 4. Header Banner with Orientation Tag
  tft.fillRect(0, 0, width, 22, ILI9341_NAVY);
  tft.setTextSize(1);
  tft.setTextColor(ILI9341_YELLOW);
  tft.setCursor(6, 7);
  tft.print("f(x) = " + equation);

  // Horizontal Mode Tag (Top Right)
  tft.setTextColor(ILI9341_GREEN);
  tft.setCursor(width - 65, 7);
  tft.print("[HORIZ]");

  // Clean equation string
  String cleanedEq = equation;
  cleanedEq.replace(" ", "");
  cleanedEq.toLowerCase();

  if (cleanedEq.startsWith("y=")) {
    cleanedEq = cleanedEq.substring(2);
  }

  // 5. Check for vertical lines (e.g. "x = 3")
  if (cleanedEq.startsWith("x=") && cleanedEq.indexOf('y') == -1) {
    String rhs = cleanedEq.substring(2); 
    MathParser parser;
    double targetX = parser.evaluate(rhs, 0); 

    if (!isnan(targetX) && !isinf(targetX)) {
      int px = (int)((targetX - xMin) / (xMax - xMin) * width);
      if (px >= 0 && px < width) {
        tft.drawFastVLine(px, 22, height - 40, ILI9341_CYAN);
      }
    }
  } else {
    // Standard y = f(x) Plotting Loop
    MathParser parser;
    int plotHeight = height - 40;
    int prevPx = -1, prevPy = -1;

    for (int px = 0; px < width; px++) {
      float x = xMin + ((float)px / (float)width) * (xMax - xMin);
      double y = parser.evaluate(cleanedEq, x);

      if (isnan(y) || isinf(y)) { prevPx = -1; continue; }

      int py = height - 18 - (int)(((y - yMin) / (yMax - yMin)) * plotHeight);

      if (py >= 22 && py < height - 18) {
        if (prevPx != -1 && abs(py - prevPy) < plotHeight / 2) {
          tft.drawLine(prevPx, prevPy, px, py, ILI9341_CYAN);
        } else {
          tft.drawPixel(px, py, ILI9341_CYAN);
        }
        prevPx = px; prevPy = py;
      } else {
        prevPx = -1;
      }
    }
  }

  // 6. Footer Bar
  tft.fillRect(0, height - 18, width, 18, ILI9341_DARKGREY);
  tft.setTextColor(ILI9341_WHITE);
  tft.setCursor(6, height - 13);
  tft.print("Mode: Graph (Landscape) | 192.168.4.1");
}
