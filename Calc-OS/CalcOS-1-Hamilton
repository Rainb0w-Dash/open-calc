// ==================== MATH EXPRESSION PARSER ====================
class MathParser {
  String expr;
  int pos = 0;
  double xVal = 0;

  char peek() {
    while (pos < expr.length() && expr[pos] == ' ') pos++;
    return (pos < expr.length()) ? expr[pos] : '\0';
  }

  char getChar() {
    char c = peek();
    if (c != '\0') pos++;
    return c;
  }

  bool match(char expected) {
    if (peek() == expected) {
      pos++;
      return true;
    }
    return false;
  }

  double parseExpression();

  double parseFactor() {
    if (match('-')) return -parseFactor();
    if (match('+')) return parseFactor();

    double result = 0;

    if (match('(')) {
      result = parseExpression();
      match(')');
    } else if ((peek() >= '0' && peek() <= '9') || peek() == '.') {
      String numStr = "";
      while ((peek() >= '0' && peek() <= '9') || peek() == '.') {
        numStr += getChar();
      }
      result = numStr.toDouble();
    } else if (match('x') || match('X')) {
      result = xVal;
    } else if (peek() >= 'a' && peek() <= 'z') {
      String func = "";
      while (peek() >= 'a' && peek() <= 'z') func += getChar();
      if (match('(')) {
        double arg = parseExpression();
        match(')');
        if (func == "sin") result = sin(arg);
        else if (func == "cos") result = cos(arg);
        else if (func == "tan") result = tan(arg);
        else if (func == "sqrt") result = sqrt(arg);
        else if (func == "abs") result = fabs(arg);
        else if (func == "ln") result = log(arg);
        else if (func == "exp") result = exp(arg);
      }
    }

    if (match('^')) {
      double exponent = parseFactor();
      result = pow(result, exponent);
    }

    return result;
  }

  double parseTerm() {
    double left = parseFactor();
    while (true) {
      if (match('*')) left *= parseFactor();
      else if (match('/')) {
        double denom = parseFactor();
        left = (denom != 0) ? left / denom : NAN;
      } else break;
    }
    return left;
  }

public:
  double evaluate(String expression, double x) {
    expr = expression;
    expr.toLowerCase();
    pos = 0;
    xVal = x;
    return parseExpression();
  }
};

double MathParser::parseExpression() {
  double left = parseTerm();
  while (true) {
    if (match('+')) left += parseTerm();
    else if (match('-')) left -= parseTerm();
    else break;
  }
  return left;
}

