void handleRoot() {
  server.send(200, "text/html", HTML_PAGE);
}

void handleSetMode() {
  if (server.hasArg("m")) {
    int m = server.arg("m").toInt();
    if (m >= 0 && m <= 3) {
      setMode((AppMode)m);
    }
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

void handlePlot() {
  if (server.hasArg("expr")) {
    currentEquation = server.arg("expr");
    setMode(MODE_GRAPH);
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

// ==================== MAIN SETUP & LOOP ====================
void setup() {
  Serial.begin(115200);

  // Initialize Hardware SPI & TFT
  SPI.begin(TFT_SCLK, TFT_MISO, TFT_MOSI, TFT_CS);
  tft.begin();

  // Initialize Wi-Fi Access Point
  WiFi.softAP(ap_ssid, ap_password);

  // Register Web Routes
  server.on("/", handleRoot);
  server.on("/setmode", handleSetMode);
  server.on("/plot", handlePlot);
  server.begin();

  // Draw Home Menu on Boot in Vertical orientation
  renderHomeScreen();
}

void loop() {
  server.handleClient();
}
